# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── Build output ──────────────────────────────────────────────────────────────
dist/
out/

# ── VS Code extension packaging ───────────────────────────────────────────────
*.vsix

# ── TypeScript ────────────────────────────────────────────────────────────────
*.js.map
*.d.ts

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS junk ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor / IDE ──────────────────────────────────────────────────────────────
# Keep .vscode/launch.json and tasks.json (useful for contributors)
# but ignore personal workspace settings
.vscode/settings.json
.vscode/*.code-workspace

# ── Test artefacts ────────────────────────────────────────────────────────────
.vscode-test/
coverage/

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
src/shared/devKeys.ts

# ── Sound files (large binary media — add your own locally) ──────────────────
media/sounds/*.mp3
media/sounds/*.ogg
media/sounds/*.wav
