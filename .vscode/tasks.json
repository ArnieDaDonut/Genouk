{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build (dev)",
      "type": "shell",
      "command": "node esbuild.config.js",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$tsc"
      ],
      "presentation": {
        "reveal": "silent"
      }
    },
    {
      "label": "Watch",
      "type": "shell",
      "command": "node esbuild.config.js --watch",
      "isBackground": true,
      "group": "build",
      "problemMatcher": [
        "$tsc-watch"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}