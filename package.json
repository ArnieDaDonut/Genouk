{
  "name": "genouk",
  "displayName": "Genouk",
  "description": "Genouk AI Assistant for prompt engineering and review",
  "version": "0.0.1",
  "publisher": "genouk-dev",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ArnieDaDonut/Genouk.git"
  },
  "bugs": {
    "url": "https://github.com/ArnieDaDonut/Genouk/issues"
  },
  "homepage": "https://github.com/ArnieDaDonut/Genouk#readme",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "categories": [
    "Other",
    "Programming Languages",
    "Machine Learning"
  ],
  "keywords": [
    "genouk",
    "AI",
    "prompt",
    "review",
    "assistant",
    "mascot",
    "linear"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "genouk.openPlanner",
        "title": "Genouk: Open Planner Window",
        "icon": "$(window)"
      },
      {
        "command": "genouk.setApiKey",
        "title": "Genouk: Set API Key",
        "icon": "$(key)"
      },
      {
        "command": "genouk.syncTodosToLinear",
        "title": "Genouk: Sync TODOs in Active File to Linear",
        "icon": "$(sync)"
      },
      {
        "command": "genouk.tourNext",
        "title": "Genouk: Live Tour Next Stop",
        "icon": "$(arrow-right)"
      },
      {
        "command": "genouk.tourPrevious",
        "title": "Genouk: Live Tour Previous Stop",
        "icon": "$(arrow-left)"
      },
      {
        "command": "genouk.testAgentDoneSound",
        "title": "Genouk: Test Agent-Done Notification Sound",
        "icon": "$(unmute)"
      }
    ],
    "keybindings": [
      {
        "command": "genouk.tourNext",
        "key": "right",
        "mac": "right",
        "when": "editorTextFocus && genouk.liveTour"
      },
      {
        "command": "genouk.tourPrevious",
        "key": "left",
        "mac": "left",
        "when": "editorTextFocus && genouk.liveTour"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "genouk-sidebar",
          "title": "Genouk",
          "icon": "$(robot)"
        }
      ]
    },
    "views": {
      "genouk-sidebar": [
        {
          "type": "webview",
          "id": "genouk.sidebar",
          "name": "Genouk",
          "icon": "$(robot)"
        }
      ]
    },
    "configuration": {
      "title": "Genouk",
      "properties": {
        "genouk.vultrApiKey": {
          "type": "string",
          "default": "",
          "description": "Fallback Vultr Serverless Inference API key. Prefer the \"Genouk: Set API Key\" command, which stores it in the OS keychain instead of plaintext settings.",
          "markdownDescription": "**Fallback only** — prefer the **Genouk: Set API Key** command (stored securely in the OS keychain). Get a key from the [Vultr Inference dashboard](https://my.vultr.com/inference/). When set, Vultr is the primary provider."
        },
        "genouk.vultrModel": {
          "type": "string",
          "default": "",
          "description": "Vultr inference model id (e.g. deepseek-ai/DeepSeek-V4-Flash). Leave blank to use the VULTR_MODEL env var or the built-in default."
        },
        "genouk.maxTokens": {
          "type": "number",
          "default": 4096,
          "minimum": 256,
          "maximum": 32768,
          "description": "Maximum tokens the model may use for a single review response."
        },
        "genouk.temperature": {
          "type": "number",
          "default": 0.4,
          "minimum": 0,
          "maximum": 2,
          "description": "Sampling temperature for reviews. Lower is more focused and deterministic."
        },
        "genouk.linearApiKey": {
          "type": "string",
          "default": "",
          "description": "Fallback Linear Personal API Key. Prefer the \"Genouk: Set API Key\" command, which stores it securely.",
          "markdownDescription": "**Fallback only** — prefer the **Genouk: Set API Key** command (stored securely in the OS keychain). Generate one at [linear.app/settings/api](https://linear.app/settings/api)."
        },
        "genouk.linearTeamId": {
          "type": "string",
          "default": "",
          "description": "Your Linear Team ID (or Team Key, e.g., ENG) where tasks will be created."
        },
        "genouk.agentDoneSound": {
          "type": "boolean",
          "default": true,
          "description": "Play Genouk's notification sound when another in-editor AI agent finishes writing code (detected when a burst of large, multi-line edits settles)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "bundle": "node esbuild.config.js --production",
    "dev": "node esbuild.config.js --watch",
    "compile": "tsc --noEmit",
    "test": "vscode-test",
    "package": "npx vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/vscode": "^1.90.0",
    "@vscode/test-cli": "^0.0.9",
    "@vscode/test-electron": "^2.3.9",
    "esbuild": "^0.21.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@linear/sdk": "^86.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "framer-motion": "^11.0.0",
    "jsonrepair": "^3.14.0",
    "lucide-react": "^0.360.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tone": "^15.1.22",
    "zod": "^3.25.76"
  }
}
