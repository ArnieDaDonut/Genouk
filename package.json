{
  "name": "detonate",
  "displayName": "Detonate",
  "description": "Blast Radius visualization, AI code explanations, and vibe-matched music for your dev workflow.",
  "version": "0.0.1",
  "publisher": "detonate-dev",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Programming Languages",
    "Visualization"
  ],
  "keywords": [
    "blast radius",
    "dependency graph",
    "code explanation",
    "AI",
    "music",
    "vibe"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "detonate.blastRadius",
        "title": "Detonate: Show Blast Radius",
        "icon": "$(flame)"
      },
      {
        "command": "detonate.explainCode",
        "title": "Detonate: Explain This Code",
        "icon": "$(lightbulb)"
      },
      {
        "command": "detonate.toggleVibe",
        "title": "Detonate: Toggle Vibe Score",
        "icon": "$(music)"
      },
      {
        "command": "detonate.connectSpotify",
        "title": "Detonate: Connect Spotify"
      },
      {
        "command": "detonate.clearBlastRadius",
        "title": "Detonate: Clear Blast Radius Highlights"
      }
    ],
    "keybindings": [
      {
        "command": "detonate.blastRadius",
        "key": "ctrl+shift+d",
        "mac": "cmd+shift+d",
        "when": "editorTextFocus"
      },
      {
        "command": "detonate.explainCode",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "editorTextFocus"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "detonate.blastRadiusTree",
          "name": "Blast Radius",
          "icon": "$(flame)",
          "contextualTitle": "Blast Radius Impact"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "detonate.blastRadius",
          "group": "detonate@1",
          "when": "editorTextFocus"
        },
        {
          "command": "detonate.explainCode",
          "group": "detonate@2",
          "when": "editorTextFocus && editorHasSelection"
        }
      ]
    },
    "configuration": {
      "title": "Detonate",
      "properties": {
        "detonate.geminiApiKey": {
          "type": "string",
          "default": "",
          "description": "Your Gemini API key for AI-powered code explanations.",
          "markdownDescription": "Get a free key at [aistudio.google.com](https://aistudio.google.com/app/apikey)"
        },
        "detonate.vibeSound": {
          "type": "boolean",
          "default": true,
          "description": "Enable sound effects that match your code health score."
        },
        "detonate.vibeVolume": {
          "type": "number",
          "default": 50,
          "minimum": 0,
          "maximum": 100,
          "description": "Volume for vibe sound effects (0-100)."
        },
        "detonate.spotifyClientId": {
          "type": "string",
          "default": "",
          "description": "Spotify App Client ID for Spotify integration."
        },
        "detonate.blastRadiusMaxDepth": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 10,
          "description": "Maximum call depth to traverse in Blast Radius analysis."
        },
        "detonate.autoBlastRadius": {
          "type": "boolean",
          "default": false,
          "description": "Automatically show Blast Radius when cursor rests on a symbol."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "bundle": "node esbuild.config.js --production",
    "dev": "node esbuild.config.js --watch",
    "compile": "tsc --noEmit",
    "test": "vscode-test",
    "package": "npx vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/test-cli": "^0.0.9",
    "@vscode/test-electron": "^2.3.9",
    "esbuild": "^0.21.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@google/generative-ai": "^0.14.0"
  }
}
