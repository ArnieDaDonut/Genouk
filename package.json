{
  "name": "jarvis",
  "displayName": "Jarvis",
  "description": "Jarvis AI Assistant for prompt engineering and review",
  "version": "0.0.1",
  "publisher": "jarvis-dev",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Programming Languages",
    "Machine Learning"
  ],
  "keywords": [
    "jarvis",
    "AI",
    "prompt",
    "review"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "jarvis-sidebar",
          "title": "Jarvis",
          "icon": "$(robot)"
        }
      ]
    },
    "views": {
      "jarvis-sidebar": [
        {
          "type": "webview",
          "id": "jarvis.sidebar",
          "name": "Jarvis Assistant",
          "icon": "$(robot)"
        }
      ]
    },
    "configuration": {
      "title": "Jarvis",
      "properties": {
        "jarvis.groqApiKey": {
          "type": "string",
          "default": "",
          "description": "Your Groq API key for Jarvis AI.",
          "markdownDescription": "Get a free key at [console.groq.com/keys](https://console.groq.com/keys)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "bundle": "node esbuild.config.js --production",
    "dev": "node esbuild.config.js --watch",
    "compile": "tsc --noEmit",
    "test": "vscode-test",
    "package": "npx vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/vscode": "^1.90.0",
    "@vscode/test-cli": "^0.0.9",
    "@vscode/test-electron": "^2.3.9",
    "esbuild": "^0.21.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@google/genai": "^2.8.0",
    "@google/generative-ai": "^0.14.0",
    "framer-motion": "^11.0.0",
    "groq-sdk": "^1.2.1",
    "lucide-react": "^0.360.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
